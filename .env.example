# =============================================================================
# Polymarket CLOB Trading Bot - Environment configuration
# Copy this file to `.env` and fill in your values.
# =============================================================================

# ---- Wallet / CLOB authentication (REQUIRED for trading) --------------------
# Polygon-compatible wallet private key. Keep this secret!
PRIVATE_KEY=your_private_key_here

# CLOB API host (default is the public Polymarket CLOB endpoint)
POLY_HOST=https://clob.polymarket.com

# Polygon chain id (137 = mainnet)
CHAIN_ID=137

# Signature type:
#   0 = standard EOA wallet (MetaMask / direct private key). Default.
#   1 = email / Magic wallet (delegated signing) -> requires FUNDER
#   2 = browser-wallet proxy (Gnosis Safe) -> requires FUNDER
#   3 = POLY_1271 deposit wallet (Polymarket V2) -> requires FUNDER
#   If you used the Polymarket web UI after V2 upgrade (Apr 2026) this is
#   likely the correct type. Find your deposit wallet address on
#   polymarket.com -> Settings -> Deposit Wallet.
SIGNATURE_TYPE=0

# Funder address (the address holding the USDC / conditional tokens).
# Required when SIGNATURE_TYPE is 1, 2 or 3. For EOA (0) leave blank.
# This is your deposit wallet / proxy wallet address, NOT your EOA.
FUNDER=

# Optional manually supplied CLOB API credentials.
# Leave blank to let the client create/derive credentials automatically.
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASSPHRASE=

# ---- Trading parameters -----------------------------------------------------
# Strategies are configured via interactive setup at startup or Telegram
# /strategy add at runtime — they are in-memory only, not persisted here.
# SHARE_AMOUNT / ENTRY_PRICE / EXIT_PRICE below serve as default values
# when pressing Enter during interactive setup.

# Order size (shares) per entry
SHARE_AMOUNT=10

# Limit prices (0.00 - 1.00 USD)
ENTRY_PRICE=0.50
EXIT_PRICE=0.55

# Exit strategy: take-profit / stop-loss as a percentage of the entry price.
# Leave blank to disable. Example: 0.10 = exit when profit >= 10% or loss >= 10%.
TAKE_PROFIT_PCT=
STOP_LOSS_PCT=

# Polling interval (seconds) between strategy cycles
POLL_INTERVAL=30

# How often (in cycles) to push a periodic status notification
STATUS_EVERY_CYCLES=20

# ---- Telegram notifications (multiple bots) ---------------------------------
# JSON array of notification bots. Each bot pushes the same message to its chat.
# TELEGRAM_BOTS=[{"token":"123:ABC","chat_id":"11111111","enabled":true}]

# ---- Telegram interactive command bot ---------------------------------------
# A single bot token that listens for commands. May reuse one of the
# TELEGRAM_BOTS tokens above. Leave blank to disable interactive commands.
TELEGRAM_INTERACTIVE_TOKEN=

# Comma-separated whitelist of Telegram user ids allowed to send commands.
# Leave blank to allow anyone (not recommended).
TELEGRAM_ALLOWED_USER_IDS=

# ---- Webhook notifications (multiple URLs) ----------------------------------
# JSON array of webhook endpoints. Each receives the same payload via POST.
# WEBHOOKS=[{"url":"https://example.com/hook","enabled":true}]

# ---- Runtime ----------------------------------------------------------------
# Path to the mutable trading-config file (created/updated by Telegram commands)
CONFIG_FILE=config.json

# ---- Conditional entry -----------------------------------------------------
# true  等 best_ask ≤ entry_price 时才下单（默认）
# false 立即挂 entry_price 的 GTC 限价买单
CONDITIONAL_ENTRY=true
