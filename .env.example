# =============================================================================
# Polymarket CLOB Trading Bot - Environment configuration
# Copy this file to `.env` and fill in your values.
#
# Architecture: asyncio multi-strategy concurrent runtime.
# Strategies are configured via interactive CLI at startup (memory-only,
# not persisted). The values below serve as CLI defaults and global settings.
# =============================================================================

# ---- Wallet / CLOB authentication (REQUIRED for trading) --------------------
# Polygon-compatible wallet private key. Keep this secret!
PRIVATE_KEY=your_private_key_here

# CLOB API host (default is the public Polymarket CLOB endpoint)
POLY_HOST=https://clob.polymarket.com

# Polygon chain id (137 = mainnet)
CHAIN_ID=137

# Signature type:
#   0 = standard EOA wallet (MetaMask / direct private key). Default.
#   1 = email / Magic wallet (delegated signing) -> requires FUNDER
#   2 = browser-wallet proxy (Gnosis Safe) -> requires FUNDER
#   3 = POLY_1271 deposit wallet (Polymarket V2) -> requires FUNDER
SIGNATURE_TYPE=0

# Funder address (the address holding the USDC / conditional tokens).
# Required when SIGNATURE_TYPE is 1, 2 or 3. For EOA (0) leave blank.
# This is your deposit wallet / proxy wallet address, NOT your EOA.
# Also used as the `user` parameter for the Polymarket data API position query.
FUNDER=

# Optional manually supplied CLOB API credentials.
# Leave blank to let the client create/derive credentials automatically.
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASSPHRASE=

# ---- Global runtime parameters ----------------------------------------------
# Master switch. Set to false to pause all trading without stopping the process.
TRADING_ENABLED=true

# Polling interval (seconds) between strategy cycles
POLL_INTERVAL=1

# Heartbeat log frequency (print status every N cycles, per strategy)
STATUS_EVERY_CYCLES=20

# ---- Conditional entry (GLOBAL, .env only — not overridable per strategy) ---
# true  = wait until best_ask <= entry_price before placing the BUY limit order
# false = place the GTC limit BUY immediately at entry_price
CONDITIONAL_ENTRY=true

# ---- CLI setup defaults (used as starting values in interactive prompts) ----
# These are NOT strategy configs — they are defaults shown when the CLI asks
# for entry/exit/size/tp/sl. Each strategy gets its own independent values.
ENTRY_PRICE=0.50
EXIT_PRICE=0.55
SHARE_AMOUNT=10

# Default take-profit / stop-loss percentages (blank = disabled by default).
# Expressed as fractions: 0.10 = 10%, 0.55 = 55%.
TAKE_PROFIT_PCT=
STOP_LOSS_PCT=

# ---- Telegram notifications (push, multiple bots) ---------------------------
# JSON array of notification bots. Each bot pushes the same message to its chat.
# TELEGRAM_BOTS=[{"token":"123:ABC","chat_id":"11111111","enabled":true}]

# ---- Webhook notifications (multiple URLs) ----------------------------------
# JSON array of webhook endpoints. Each receives the same payload via POST.
# WEBHOOKS=[{"url":"https://example.com/hook","enabled":true}]
